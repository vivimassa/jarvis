# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environment
.venv/
venv/

# Secrets & runtime state — never commit these
config/api_keys.json
config/settings.json
config/briefing_state.json
config/usage_stats.json
memory/*.json

# TLS certs for the optional local dashboard — self-signed, generated per-install
config/certs/

# PyInstaller build output
build/
dist/
*.spec

# Bundled 3rd-party tool (LibreHardwareMonitor) — download separately
tools/

# Logs
*.log
logs/

# OS
Thumbs.db
desktop.ini
